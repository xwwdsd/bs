<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cs2trade.mapper.PlayerShowCommentMapper">

    <resultMap id="BaseResultMap" type="com.cs2trade.entity.PlayerShowComment">
        <id column="id" property="id" />
        <result column="show_id" property="showId" />
        <result column="user_id" property="userId" />
        <result column="content" property="content" />
        <result column="created_at" property="createdAt" />
        <result column="username" property="username" />
        <result column="avatar" property="avatar" />
    </resultMap>

    <select id="selectByShowId" resultMap="BaseResultMap">
        SELECT c.*, u.username, u.avatar
        FROM sys_player_show_comment c
        LEFT JOIN sys_user u ON c.user_id = u.id
        WHERE c.show_id = #{showId}
        ORDER BY c.created_at DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_player_show_comment (show_id, user_id, content, created_at)
        VALUES (#{showId}, #{userId}, #{content}, NOW())
    </insert>

</mapper>
